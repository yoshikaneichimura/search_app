<!DOCTYPE html>
<html>
  <head>
    <title>SearchApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script src="https://kit.fontawesome.com/a5fc0fa3f9.js" crossorigin="anonymous"></script>
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>

    <div class="container">
      <div class="row">
        <div class="col">
          <h6 class="text-danger">Bootstrap</h6>
        </div>
        <div class="col">
           <h6 class="text-red">SCSS</h6>
        </div>
      </div>
    </div>
    <hr>

    <header>
      <div class="container">
        <div class="row">
          <div class="col-6">
            <nav>
              <ul class="nav nav-fill">
                <% if user_signed_in? %>
                  <li class="nav-item">
                    <%= link_to "new", new_post_path ,class: "nav-link text-secondary" %>
                  </li>
                  <li class="nav-item">
                    <%= link_to "index", posts_path ,class: "nav-link text-secondary" %>
                  </li>
                  <li class="nav-item">
                    <%= link_to "users", users_path ,class: "nav-link text-secondary" %>
                  </li>
                  <li class="nav-item">
                    <%= link_to "ログアウト", destroy_user_session_path, method: :delete ,class: "nav-link text-secondary" %>
                  </li>
                <% else %>
                  <li class="nav-item">
                    <%= link_to "新規登録", new_user_registration_path ,class: "nav-link text-secondary" %>
                  </li>
                  <li class="nav-item">
                    <%= link_to "ログイン", new_user_session_path ,class: "nav-link text-secondary" %>
                  </li>
                <% end %>
              </ul>
            </nav>
          </div>
          <div class="col-4">

            <%= render 'posts/search_form' , search_form: @search_form %>

          </div>
          <div class="col-2">

            <%= render 'posts/modal' , search_form: @search_form %>

          </div>
        </div>
      </div>
    </header>

    <div class="d-flex justify-content-center">
      <div><%= flash[:notice]%></div>
    </div>

    <%= yield %>
  </body>
</html>
