<div class="container">

  <%= search_form_for search_form, url: posts_path do |f| %>
    <%= f.label :title_cont, "検索ワード"%>
    <%= f.search_field :title_cont, placeholder: "検索ワード" %><br>

    <%= f.label :user_name_cont, "ユーザー名" %>
    <%= f.collection_select :user_name_cont, User.all, :name, :name, include_blank: "指定なし" %><br>

    <%= f.label :price, "価格" %>
    <%= f.number_field :price_gteq %> 以上〜
    <%= f.number_field :price_lteq %> 以下<br>

    <%= f.label :day, "発売日" %>
    <%= f.date_field :day_gteq %> 〜
    <%= f.date_field :day_lteq %>

    <%= f.label :status, "販売状況" %>
    <%= f.radio_button :status_eq, '' %>指定なし
    <%= f.radio_button :status_eq, true %>販売中
    <%= f.radio_button :status_eq, false %>廃盤<br>
    <%= f.submit '検索'%>
  <% end %>
</div>