<div class="container">

  <h2 class="text-center mt-3">EDIT</h2>

  <% if @post.errors.any? %>
    <%= @post.errors.count %>件のエラーが発生しました。
    <ul>
      <% @post.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with model: @post, url: post_path(@post.id), method: :patch do |f| %>
  <form>
    <div class="mx-auto w-50">
      <div>
        <div class="form-group">
          <label>TITLE</label>
          <%= f.text_field :title ,class: "form-control"; %>
        </div>
        <div class="form-group">
          <label>BODY</label>
          <%= f.text_area :body ,class: "form-control"; %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group mr-3">
        <label>PRICE</label>
        <%= f.text_field :price ,class: "form-control"; %>
        </div>
        <div class="form-group mr-3">
          <label>DAY</label>
          <%= f.date_field :day ,class: "form-control"; %>
        </div>
        <fieldset class="form-group ml-3">
          <div class="row">
            <div class="form-check">
              <label>STATUS</label></br>
              <div class="ml-3">
                <%= f.radio_button(:status, "false" ,class: "form-check-input") %>
                <%= f.label(:status, "false") %></br>
                <%= f.radio_button(:status, "true" ,class: "form-check-input")  %>
                <%= f.label(:status, "true") %><br>
              </div>
            </div>
          </div>
        </fieldset>
      </div>
      <%= f.submit "投稿" , class: "btn btn-success";%>
    </div>
  </form>
  <% end %>
</div>