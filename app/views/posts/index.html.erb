<div class="container">
  <h2>INDEX</h2>
  <select class="ui fluid dropdown form-control w-50 mb-3" onChange="location.href=value;">
    <option value="">並び替え</option>
    <option value="<%= sort_by_sort_url(sort_url(@search_form, :created_at), 'created_at+desc') %>">新着順</option>
    <option value="<%= sort_by_sort_url(sort_url(@search_form, :created_at), 'created_at+asc') %>">古い順</option>
    <option value="<%= sort_by_sort_url(sort_url(@search_form, :price), 'price+desc') %>">価格が高い順</option>
    <option value="<%= sort_by_sort_url(sort_url(@search_form, :price), 'price+asc') %>">価格が安い順</option>
  </select>
  <table class="table table-hover">
    <thead class="thead-light">
      <tr>
      <th>TITLE</th>
      <th>BODY</th>
      <th>PRICE</th>
      <th></th>
    </tr>
    </thead>

    <% @posts.each do |post| %>
    <tbody>
      <tr>
        <td><%= link_to "#{post.title}", post_path(post.id) ,class: "text-secondary" %></td>
        <td class="text-secondary"><%= post.price %></td>
        <td class="text-secondary"><%= post.day %></td>
        <td><%= link_to "#{post.user.name}", user_path(post.user.name) ,class: "text-secondary" %></td>
      </tr>
    </tbody>
    <% end %>
  </table>
</div>

